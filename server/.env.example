# MongoDB Connection String
# Get this from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/expensetracker

# OpenAI API Key
# Get this from: https://platform.openai.com/api-keys
# Must start with "sk-"
OPENAI_API_KEY=sk-your-openai-api-key-here

# Server Configuration
# Port to run the server on (default: 5000)
PORT=5000

# Environment mode
# Use "development" for local development
# Use "production" for production deployment
NODE_ENV=development
